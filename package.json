{
  "name": "xingju",
  "version": "1.0.0",
  "description": "星聚 - Windows版多元内容聚合工具",
  "main": "dist/main/index.js",
  "author": "XingJu Team",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:python\"",
    "dev:main": "electron dist/main/index.js",
    "dev:renderer": "vite",
    "dev:python": "python src/python/main.py",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:win:portable": "npm run build && electron-builder --win --portable",
    "lint": "eslint src --ext .ts,.vue",
    "test": "jest",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron": "^25.9.8",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/tsconfig": "^0.5.0",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.3.0",
    "vue-tsc": "^1.8.0"
  },
  "build": {
    "appId": "com.xingju.app",
    "productName": "星聚",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/python/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src/python",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
